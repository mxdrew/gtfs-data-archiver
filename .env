# Core settings and stream controls
API_KEY=YOUR_API_KEY_HERE
SYNC_TIMEZONE=America/New_York
AGENCY_NAME=MBTA
BASE_URL=https://api-v3.mbta.com
GTFS_URL=https://cdn.mbta.com/MBTA_GTFS.zip
ENABLE_BASE_STREAMS=true
ENABLE_ROUTE_STREAMS=true
ENABLE_SNAPSHOT_PULLS=true
ENABLE_ENHANCED_STREAMS=true
ENABLE_GTFS_STATIC=true

# Stream and snapshot targets
BASE_STREAMS=vehicles,alerts
ROUTE_STREAMS=predictions,stop_events
SNAPSHOT_EPS=schedules,services,shapes,trips,lines,routes,route_patterns,facilities,stops,live_facilities

# Enhanced bulk feed settings
ENHANCED_POLL_INTERVAL_SECONDS=7
VEHICLES_ENHANCED_URL=https://cdn.mbta.com/realtime/VehiclePositions_enhanced.json
ALERTS_ENHANCED_URL=https://cdn.mbta.com/realtime/Alerts_enhanced.json
TRIPS_ENHANCED_URL=https://cdn.mbta.com/realtime/TripUpdates_enhanced.json

# Tuning and logging
DEFAULT_BATCH_SIZE=25
LOG_LEVEL=warning
ARCHIVE_ZSTD_LEVEL=10
GTFS_DOWNLOAD_USER_AGENT=

# Shared script paths
DATA_DIR=./data
DATA_DIR_WSL=/mnt/c/path/to/gtfs-data-archiver/data

# MBTA credentials for scripts (used by otherScripts/ma-gtfs-archiver.py)
MBTA_API_KEY=

# BusTime script (otherScripts/bustime.py)
BUSTIME_AGENCY=
BUSTIME_BASE_URL=
BUSTIME_API_KEY=
GTFS_FEED_URL=
VERBOSE_LOGGING=

# RouteMatch script (otherScripts/routematch.py)
ROUTEMATCH_AGENCY=
ROUTEMATCH_BASE_URL=
ROUTEMATCH_REFERER=

# PassioGo script (otherScripts/passigo.py)
PASSIOGO_AGENCY_CATALOG=0000:AGENCY_A,0001:AGENCY_B
PASSIOGO_TARGET_AGENCY_IDS=0000,0001
PASSIOGO_SAVE_ACTIVE_JSON=
